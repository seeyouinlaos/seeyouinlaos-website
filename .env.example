# See You In Laos — Flight Tracker Travel Service configuration.
# Copy the real values into the Netlify site's environment variables
# (Site settings → Environment variables). NEVER commit real keys.
# The browser never sees these; only the serverless Travel Service reads them.

# --- Provider selection ---
PROVIDER=duffel

# --- Duffel credentials (https://app.duffel.com → Developer → Access tokens) ---
# Test token starts "duffel_test_", live token starts "duffel_live_".
DUFFEL_ACCESS_TOKEN=duffel_test_your-access-token
# Optional: pin the Duffel API version (defaults to v2 in the adapter).
DUFFEL_VERSION=v2

# --- CORS (optional): restrict the Travel Service to your site origin ---
SITE_ORIGIN=https://seeyouinlaos.netlify.app

# --- Alerts (optional): delivery channel for "notify below" ---
# log (default, writes to function logs) | email (seam, wire an ESP to enable)
NOTIFY_CHANNEL=log
NOTIFY_EMAIL_FROM=
