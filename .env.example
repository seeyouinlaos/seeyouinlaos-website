# See You In Laos — Flight Tracker Travel Service configuration (Cloudflare Worker).
#
# On Cloudflare, configuration is NOT a committed .env file:
#   - non-secret vars live in wrangler.jsonc  ->  "vars"
#   - SECRETS are set on the Worker and never committed:
#       npx wrangler secret put DUFFEL_ACCESS_TOKEN
#   - the KV namespace id goes in wrangler.jsonc "kv_namespaces"
# This file documents what to set. The browser never sees any of it.

# --- Provider selection (wrangler.jsonc vars) ---
PROVIDER=duffel

# --- Duffel token (SECRET — set via `wrangler secret put DUFFEL_ACCESS_TOKEN`) ---
# Test token starts "duffel_test_", live token "duffel_live_".
DUFFEL_ACCESS_TOKEN=duffel_test_your-access-token
# Optional: pin the Duffel API version (defaults to v2 in the adapter).
DUFFEL_VERSION=v2

# --- CORS (wrangler.jsonc vars): restrict the Travel Service to your site origin ---
SITE_ORIGIN=https://seeyouinlaos.pages.dev

# --- Alerts (wrangler.jsonc vars): delivery channel for "notify below" ---
# log (default, writes to Worker logs) | email (seam, wire an ESP to enable)
NOTIFY_CHANNEL=log
NOTIFY_EMAIL_FROM=

# --- Exchange-rate source (wrangler.jsonc vars) ---
# Only used when the flight provider can't return the requested currency; rates
# are cached (KV) and converted once, never mutating the provider-native value.
#   static            indicative offline table (default fallback, no network)
#   ecb               European Central Bank daily reference rates (no key)
#   exchangerate.host free, no key
#   openexchangerates needs OXR_APP_ID          (SECRET)
#   fixer             needs FIXER_API_KEY        (SECRET)
#   currencylayer     needs CURRENCYLAYER_KEY    (SECRET)
FX_PROVIDER=ecb
# OXR_APP_ID=
# FIXER_API_KEY=
# CURRENCYLAYER_KEY=
